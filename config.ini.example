# 深知可信搜索 API 配置文件
#
# 获取 API Key：
# 1. 访问 https://platform.dknowc.cn/
# 2. 注册并登录深知平台
# 3. 获取深知可信搜索 API Key
# 4. 将本文件复制为 config.ini
# 5. 把 your_api_key_here 替换为实际 API Key
#
# 搜索接口默认使用：https://open.dknowc.cn/dependable/search/
# 如客户环境使用专属接口，可修改 base_url。

[dkag]
base_url=https://open.dknowc.cn/dependable/search/
api_key=your_api_key_here
